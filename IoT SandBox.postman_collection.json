  "item": [
    {
      "name": "devices tests",
      "item": [
        {
          "name": "Get devices",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const json = pm.response.json();\r",
                  "pm.test(\"Response contains meta object\", function () {\r",
                  "    pm.expect(json.meta.status).to.eql(\"success\")\r",
                  "})\r",
                  "pm.test(\"devices exist and is array\", function(){\r",
                  "    pm.expect(json.devices).to.be.an('array')\r",
                  "    pm.expect(json.devices).to.not.be.null\r",
                  "})"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{Base_URL}}/devices",
              "host": [
                "{{Base_URL}}"
              ],
              "path": [
                "devices"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Devices contain",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();\r",
                  "\r",
                  "pm.test(\"devices have id, type, room, online\", function(){\r",
                  "    json.devices.forEach(function(device){ \r",
                  "        pm.expect(device).to.have.property('id');\r",
                  "        pm.expect(device).to.have.property('type');\r",
                  "        pm.expect(device).to.have.property('room');\r",
                  "        pm.expect(device).to.have.property('online');\r",
                  "    })\r",
                  "})"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{Base_URL}}/devices",
              "host": [
                "{{Base_URL}}"
              ],
              "path": [
                "devices"
              ]
            }
          },
          "response": []
