        {
          "name": "num of types",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();\r",
                  "\r",
                  "const Sockets = json.devices.filter(s => s.type === 'Socket');\r",
                  "const WaterLeakSensors = json.devices.filter(s => s.type === 'WaterLeakSensor');\r",
                  "const TemperatureSensors = json.devices.filter(s => s.type === 'TemperatureSensor');\r",
                  "const Lights = json.devices.filter(s => s.type === 'Light');\r",
                  "\r",
                  "pm.test(\"4 sockets, 2 water, 1 temp, 1 light\", function(){\r",
                  "    pm.expect(Sockets.length).to.eql(4);\r",
                  "    pm.expect(WaterLeakSensors.length).to.eql(2);\r",
                  "    pm.expect(TemperatureSensors.length).to.eql(1);\r",
                  "    pm.expect(Lights.length).to.eql(1);\r",
                  "})"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{Base_URL}}/devices",
              "host": [
                "{{Base_URL}}"
              ],
              "path": [
                "devices"
              ]
            }
          },
          "response": []
        },
